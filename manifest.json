{
  "name": "All-in-One Message Notifications",
  "short_name": "All-in-One Message Notifier",
  "version": "1.1.7",
  "manifest_version": 3,
  "description": "Improve your productivy, don't lose your focus. Monitor messages and notifications from multiple tabs in one place.",
  "author": "Danilo da Silveira Figueira",
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon128.png",
    "default_title": "All-in-One Message Notifier",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "windows",
    "offscreen"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "options_page": "popup.html",
  "homepage_url": "https://github.com/asfixia/Inbox-Radar",
  "offline_enabled": true
}
